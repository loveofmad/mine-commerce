.page-order-detail {
  padding-bottom: 140rpx;
  background: linear-gradient(180deg, #f0f4f8 0%, #e8ecf1 100%);
  min-height: 100vh;
}

/* 状态头部 */
.status-section {
  padding: 48rpx 30rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.status-section::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.status-bg-0 { background: linear-gradient(135deg, #E07A5F 0%, #E8967E 100%); }
.status-bg-1 { background: linear-gradient(135deg, #4A90A4 0%, #6BB0C4 100%); }
.status-bg-2 { background: linear-gradient(135deg, #52A88C 0%, #6BBEAA 100%); }
.status-bg-3 { background: linear-gradient(135deg, #95A5A6 0%, #B0BEC5 100%); }
.status-bg-4 { background: linear-gradient(135deg, #D44848 0%, #E06060 100%); }

.status-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.status-icon {
  font-size: 44rpx;
}

.status-text {
  font-size: 38rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.85;
}

/* 信息卡片 */
.info-section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 164, 0.08);
  border: 1rpx solid rgba(74, 144, 164, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F4F8;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E50;
}

/* 收货地址 */
.address-card {
  background: linear-gradient(135deg, #F8FBFC 0%, #F0F4F8 100%);
  border-radius: 14rpx;
  padding: 20rpx;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 26rpx;
  color: #5D6D7E;
}

.address-detail {
  font-size: 26rpx;
  color: #5D6D7E;
  line-height: 1.5;
}

/* 商品列表 */
.goods-list {
  margin-top: 4rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F4F8;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 14rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.goods-image {
  width: 100%;
  height: 100%;
}

.goods-info {
  flex: 1;
  min-width: 0;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #2C3E50;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.goods-sku {
  font-size: 22rpx;
  color: #95A5A6;
  background: #F0F4F8;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.goods-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
}

.goods-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #E07A5F;
}

.goods-qty {
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 8rpx;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F0F4F8;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #95A5A6;
}

.info-value {
  font-size: 26rpx;
  color: #2C3E50;
  max-width: 60%;
  text-align: right;
}

.info-value.remark {
  color: #E07A5F;
  font-style: italic;
}

.info-value.discount {
  color: #52A88C;
  font-weight: 600;
}

.total-row {
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F4F8;
  border-bottom: none;
}

.total-price-wrap {
  display: flex;
  align-items: baseline;
}

.total-price-symbol {
  font-size: 26rpx;
  color: #E07A5F;
  font-weight: 600;
}

.total-price {
  font-size: 40rpx;
  color: #E07A5F;
  font-weight: 700;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
  padding: 0 30rpx;
  border-top: 1rpx solid #F0F4F8;
  box-shadow: 0 -4rpx 20rpx rgba(74, 144, 164, 0.08);
  z-index: 100;
}

.action-btn {
  padding: 0 40rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.action-cancel {
  background: #F0F4F8;
  color: #5D6D7E;
}

.action-pay {
  background: linear-gradient(135deg, #E07A5F 0%, #E8967E 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(224, 122, 95, 0.35);
}

.action-confirm {
  background: linear-gradient(135deg, #52A88C 0%, #6BBEAA 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(82, 168, 140, 0.35);
}

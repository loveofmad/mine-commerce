.page-order-list {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f0f4f8 0%, #e8ecf1 100%);
}

/* 顶部标签栏 */
.order-tabs {
  display: flex;
  background: #fff;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 164, 0.06);
  position: relative;
  z-index: 10;
}

.order-tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #5D6D7E;
  font-weight: 500;
  position: relative;
  transition: all 0.3s;
}

.order-tab.active {
  color: #E07A5F;
  font-weight: 700;
}

.order-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #E07A5F 0%, #E8967E 100%);
  border-radius: 3rpx;
}

/* 订单列表 */
.order-scroll {
  flex: 1;
  padding: 20rpx 24rpx;
}

/* 订单卡片 */
.order-item {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 164, 0.08);
  border: 1rpx solid rgba(74, 144, 164, 0.06);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
  border-bottom: 1rpx solid #F0F4F8;
}

.order-no-wrap {
  display: flex;
  align-items: center;
}

.order-no-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.order-no {
  font-size: 24rpx;
  color: #5D6D7E;
  font-family: monospace;
}

.order-status-tag {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.status-0 { background: rgba(224, 122, 95, 0.1); color: #E07A5F; }
.status-0 .status-dot { background: #E07A5F; }
.status-1 { background: rgba(74, 144, 164, 0.1); color: #4A90A4; }
.status-1 .status-dot { background: #4A90A4; }
.status-2 { background: rgba(82, 168, 140, 0.1); color: #52A88C; }
.status-2 .status-dot { background: #52A88C; }
.status-3 { background: rgba(149, 165, 166, 0.1); color: #95A5A6; }
.status-3 .status-dot { background: #95A5A6; }
.status-4 { background: rgba(214, 72, 72, 0.1); color: #D44848; }
.status-4 .status-dot { background: #D44848; }

/* 商品列表 */
.order-goods {
  padding: 16rpx 24rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F4F8;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 14rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.goods-image {
  width: 100%;
  height: 100%;
}

.goods-info {
  flex: 1;
  min-width: 0;
}

.goods-name {
  font-size: 28rpx;
  color: #2C3E50;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.goods-sku {
  font-size: 22rpx;
  color: #95A5A6;
  background: #F0F4F8;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.goods-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
}

.goods-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #E07A5F;
}

.goods-qty {
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 8rpx;
}

/* 订单底部 */
.order-footer {
  border-top: 1rpx solid #F0F4F8;
  padding: 20rpx 24rpx;
}

.order-amount-wrap {
  display: flex;
  justify-content: flex-end;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.order-amount-label {
  font-size: 24rpx;
  color: #5D6D7E;
}

.order-amount {
  font-size: 34rpx;
  font-weight: 700;
  color: #E07A5F;
  margin-left: 4rpx;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn {
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.action-cancel {
  background: #F0F4F8;
  color: #5D6D7E;
}

.action-pay {
  background: linear-gradient(135deg, #E07A5F 0%, #E8967E 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(224, 122, 95, 0.3);
}

.action-confirm {
  background: linear-gradient(135deg, #52A88C 0%, #6BBEAA 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(82, 168, 140, 0.3);
}

.action-detail {
  background: #F0F4F8;
  color: #4A90A4;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #E8F4F8 0%, #D4ECEE 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 164, 0.12);
}

.empty-icon-text {
  font-size: 72rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #95A5A6;
}

/* 加载状态 */
.loading-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #E8ECF1;
  border-top-color: #4A90A4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #95A5A6;
}

.line-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.line {
  width: 100rpx;
  height: 1rpx;
  background: #E8ECF1;
}

.end-text {
  font-size: 24rpx;
  color: #95A5A6;
}

.page-order-list {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.order-tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.order-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
}

.order-tab.active {
  color: #E07A5F;
  border-bottom: 4rpx solid #E07A5F;
}

.order-scroll {
  flex: 1;
  padding: 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 26rpx;
  color: #666;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

.status-0 { color: #E07A5F; }
.status-1 { color: #409eff; }
.status-2 { color: #67c23a; }
.status-3 { color: #909399; }
.status-4 { color: #f56c6c; }

.order-content {
  padding: 20rpx 24rpx;
}

.order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-amount {
  font-size: 30rpx;
  font-weight: bold;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-goods {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.goods-item {
  display: flex;
  margin-bottom: 12rpx;
}

.goods-item:last-child {
  margin-bottom: 0;
}

.goods-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 26rpx;
  color: #333;
}

.goods-sku {
  font-size: 22rpx;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 26rpx;
  font-weight: bold;
}

.goods-qty {
  font-size: 22rpx;
  color: #999;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.action-btn.cancel {
  border: 1rpx solid #ddd;
  color: #666;
}

.action-btn.pay {
  background-color: #E07A5F;
  color: #fff;
}

.action-btn.confirm {
  background-color: #67c23a;
  color: #fff;
}

.action-btn.detail {
  border: 1rpx solid #ddd;
  color: #666;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.loading-tip {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
}

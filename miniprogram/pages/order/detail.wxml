<view class="page-order-detail" wx:if="{{order}}">
  <!-- 订单状态头部 -->
  <view class="status-section status-bg-{{order.status}}">
    <view class="status-icon-wrap">
      <text class="status-icon">{{order.status === 0 ? '💳' : order.status === 1 ? '📦' : order.status === 2 ? '🚚' : order.status === 3 ? '✅' : '❌'}}</text>
    </view>
    <text class="status-text">{{order.status === 0 ? '待付款' : order.status === 1 ? '待发货' : order.status === 2 ? '待收货' : order.status === 3 ? '已完成' : '已取消'}}</text>
    <text class="status-desc" wx:if="{{order.status === 0}}">请尽快完成支付</text>
    <text class="status-desc" wx:if="{{order.status === 1}}">商家正在备货中</text>
    <text class="status-desc" wx:if="{{order.status === 2}}">商品已发出，请注意查收</text>
    <text class="status-desc" wx:if="{{order.status === 3}}">感谢您的购买</text>
    <text class="status-desc" wx:if="{{order.status === 4}}">订单已取消</text>
  </view>

  <!-- 收货信息 -->
  <view class="info-section">
    <view class="section-header">
      <text class="section-icon">📍</text>
      <text class="section-title">收货信息</text>
    </view>
    <view class="address-card">
      <view class="address-header">
        <text class="address-name">{{order.receiverName}}</text>
        <text class="address-phone">{{order.receiverPhone}}</text>
      </view>
      <text class="address-detail">{{order.receiverAddress}}</text>
    </view>
  </view>

  <!-- 商品信息 -->
  <view class="info-section">
    <view class="section-header">
      <text class="section-icon">🛍</text>
      <text class="section-title">商品信息</text>
    </view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{orderItems}}" wx:key="id" bindtap="onProductTap" data-id="{{item.spuId}}">
        <view class="goods-image-wrap">
          <image class="goods-image" src="{{item.skuImage}}" mode="aspectFill" />
        </view>
        <view class="goods-info">
          <text class="goods-name">{{item.spuName}}</text>
          <text class="goods-sku" wx:if="{{item.skuTitle}}">{{item.skuTitle}}</text>
        </view>
        <view class="goods-right">
          <text class="goods-price">¥{{item.price}}</text>
          <text class="goods-qty">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="info-section">
    <view class="section-header">
      <text class="section-icon">📋</text>
      <text class="section-title">订单信息</text>
    </view>
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">创建时间</text>
      <text class="info-value">{{order.createTime}}</text>
    </view>
    <view class="info-row" wx:if="{{order.payTime}}">
      <text class="info-label">支付时间</text>
      <text class="info-value">{{order.payTime}}</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="info-label">备注</text>
      <text class="info-value remark">{{order.remark}}</text>
    </view>
  </view>

  <!-- 金额信息 -->
  <view class="info-section">
    <view class="section-header">
      <text class="section-icon">💰</text>
      <text class="section-title">金额信息</text>
    </view>
    <view class="info-row">
      <text class="info-label">商品金额</text>
      <text class="info-value">¥{{order.totalAmountText}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">运费</text>
      <text class="info-value">¥{{order.freightAmount || '0.00'}}</text>
    </view>
    <view class="info-row" wx:if="{{order.discountAmount > 0}}">
      <text class="info-label">优惠金额</text>
      <text class="info-value discount">-¥{{order.discountAmount}}</text>
    </view>
    <view class="info-row total-row">
      <text class="info-label">实付金额</text>
      <view class="total-price-wrap">
        <text class="total-price-symbol">¥</text>
        <text class="total-price">{{order.payAmountText}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="action-btn action-cancel" wx:if="{{order.status === 0}}" bindtap="onCancelOrder">取消订单</view>
    <view class="action-btn action-pay" wx:if="{{order.status === 0}}" bindtap="onPayOrder">💰 立即支付</view>
    <view class="action-btn action-confirm" wx:if="{{order.status === 2}}" bindtap="onConfirmOrder">✅ 确认收货</view>
  </view>
</view>

<view class="page-order-list">
  <!-- 订单状态标签 -->
  <view class="order-tabs">
    <view class="order-tab {{currentTab === -1 ? 'active' : ''}}" bindtap="onTabChange" data-tab="-1">全部</view>
    <view class="order-tab {{currentTab === 0 ? 'active' : ''}}" bindtap="onTabChange" data-tab="0">待付款</view>
    <view class="order-tab {{currentTab === 1 ? 'active' : ''}}" bindtap="onTabChange" data-tab="1">待发货</view>
    <view class="order-tab {{currentTab === 2 ? 'active' : ''}}" bindtap="onTabChange" data-tab="2">待收货</view>
    <view class="order-tab {{currentTab === 3 ? 'active' : ''}}" bindtap="onTabChange" data-tab="3">已完成</view>
  </view>

  <!-- 订单列表 -->
  <scroll-view class="order-scroll" scroll-y>
    <view class="order-item" wx:for="{{orderList}}" wx:key="id">
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-no-wrap">
          <text class="order-no-icon">📋</text>
          <text class="order-no">{{item.orderNo}}</text>
        </view>
        <view class="order-status-tag status-{{item.status}}">
          <text class="status-dot"></text>
          <text class="status-text">{{item.status === 0 ? '待付款' : item.status === 1 ? '待发货' : item.status === 2 ? '待收货' : item.status === 3 ? '已完成' : '已取消'}}</text>
        </view>
      </view>

      <!-- 商品列表 -->
      <view class="order-goods" wx:if="{{item.items && item.items.length > 0}}">
        <view class="goods-item" wx:for="{{item.items}}" wx:key="id" wx:for-item="goods" bindtap="onProductTap" data-id="{{goods.spuId}}">
          <view class="goods-image-wrap">
            <image class="goods-image" src="{{goods.skuImage}}" mode="aspectFill" />
          </view>
          <view class="goods-info">
            <text class="goods-name">{{goods.spuName}}</text>
            <text class="goods-sku">{{goods.skuTitle}}</text>
          </view>
          <view class="goods-right">
            <text class="goods-price">¥{{goods.price}}</text>
            <text class="goods-qty">x{{goods.quantity}}</text>
          </view>
        </view>
      </view>

      <!-- 订单底部 -->
      <view class="order-footer">
        <view class="order-amount-wrap">
          <text class="order-amount-label">共{{item.items.length}}件商品 合计：</text>
          <text class="order-amount">¥{{item.totalAmountText}}</text>
        </view>
        <view class="order-actions">
          <view class="action-btn action-cancel" wx:if="{{item.status === 0}}" bindtap="onCancelOrder" data-id="{{item.id}}">取消</view>
          <view class="action-btn action-pay" wx:if="{{item.status === 0}}" bindtap="onPayOrder" data-id="{{item.id}}">💰 去支付</view>
          <view class="action-btn action-confirm" wx:if="{{item.status === 2}}" bindtap="onConfirmOrder" data-id="{{item.id}}">✅ 确认收货</view>
          <view class="action-btn action-detail" bindtap="onOrderDetail" data-id="{{item.id}}">查看详情 ›</view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-tip" wx:if="{{!loading && orderList.length === 0}}">
      <view class="empty-icon-wrap">
        <text class="empty-icon-text">📦</text>
      </view>
      <text class="empty-title">暂无订单</text>
      <text class="empty-desc">快去下单吧~</text>
    </view>

    <view class="loading-tip" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view class="loading-tip" wx:if="{{!hasMore && orderList.length > 0}}">
      <view class="line-divider">
        <view class="line"></view>
        <text class="end-text">没有更多了</text>
        <view class="line"></view>
      </view>
    </view>
  </scroll-view>
</view>

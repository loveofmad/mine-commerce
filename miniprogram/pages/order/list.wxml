<view class="page-order-list">
  <!-- 订单状态标签 -->
  <view class="order-tabs">
    <view class="order-tab {{currentTab === -1 ? 'active' : ''}}" bindtap="onTabChange" data-tab="-1">全部</view>
    <view class="order-tab {{currentTab === 0 ? 'active' : ''}}" bindtap="onTabChange" data-tab="0">待付款</view>
    <view class="order-tab {{currentTab === 1 ? 'active' : ''}}" bindtap="onTabChange" data-tab="1">待发货</view>
    <view class="order-tab {{currentTab === 2 ? 'active' : ''}}" bindtap="onTabChange" data-tab="2">待收货</view>
    <view class="order-tab {{currentTab === 3 ? 'active' : ''}}" bindtap="onTabChange" data-tab="3">已完成</view>
  </view>

  <!-- 订单列表 -->
  <scroll-view class="order-scroll" scroll-y>
    <view class="order-item" wx:for="{{orderList}}" wx:key="id">
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <text class="order-status status-{{item.status}}">{{item.status === 0 ? '待付款' : item.status === 1 ? '待发货' : item.status === 2 ? '待收货' : item.status === 3 ? '已完成' : '已取消'}}</text>
      </view>
      <view class="order-content" bindtap="onOrderDetail" data-id="{{item.id}}">
        <view class="order-info">
          <text class="order-amount">订单金额：¥{{item.totalAmountText}}</text>
          <text class="order-time">{{item.createTime}}</text>
        </view>
      </view>
      <view class="order-actions">
        <view class="action-btn cancel" wx:if="{{item.status === 0}}" bindtap="onCancelOrder" data-id="{{item.id}}">取消订单</view>
        <view class="action-btn pay" wx:if="{{item.status === 0}}" bindtap="onPayOrder" data-id="{{item.id}}">立即支付</view>
        <view class="action-btn confirm" wx:if="{{item.status === 2}}" bindtap="onConfirmOrder" data-id="{{item.id}}">确认收货</view>
        <view class="action-btn detail" bindtap="onOrderDetail" data-id="{{item.id}}">查看详情</view>
      </view>
    </view>

    <view class="empty-tip" wx:if="{{!loading && orderList.length === 0}}">
      <text>暂无订单</text>
    </view>

    <view class="loading-tip" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <view class="loading-tip" wx:if="{{!hasMore && orderList.length > 0}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>
</view>

.page-order {
  padding-bottom: 140rpx;
  background: #f0f4f8;
  min-height: 100vh;
}

/* 地址区域 */
.address-section {
  background: #fff;
  padding: 30rpx;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 164, 0.06);
}

.address-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.address-content {
  flex: 1;
}

.address-info {
  margin-bottom: 8rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
  color: #2C3E50;
}

.address-phone {
  font-size: 28rpx;
  color: #5D6D7E;
}

.address-detail {
  font-size: 26rpx;
  color: #95A5A6;
  line-height: 1.5;
}

.address-empty {
  flex: 1;
  text-align: center;
  color: #E07A5F;
  font-size: 28rpx;
}

.arrow-icon {
  width: 28rpx;
  height: 28rpx;
  margin-left: 10rpx;
  flex-shrink: 0;
  opacity: 0.3;
}

/* 商品列表 */
.order-items {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 164, 0.06);
}

.order-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F4F8;
}

.order-item:last-child {
  border-bottom: none;
}

.item-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.item-title {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
  color: #2C3E50;
}

.item-sku {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #95A5A6;
  background: #F0F4F8;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-bottom .price {
  font-size: 34rpx;
}

/* 备注区域 */
.remark-section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 164, 0.06);
}

.remark-label {
  font-size: 28rpx;
  color: #2C3E50;
  margin-right: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.remark-input {
  flex: 1;
  font-size: 28rpx;
  text-align: right;
}

/* 金额区域 */
.amount-section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 164, 0.06);
}

.amount-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #5D6D7E;
}

.amount-row.total {
  border-top: 1rpx solid #F0F4F8;
  margin-top: 10rpx;
  padding-top: 20rpx;
  font-weight: 600;
  color: #2C3E50;
}

.amount-row .price {
  font-size: 34rpx;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #E8ECF1;
  padding: 0 30rpx;
  z-index: 100;
  box-shadow: 0 -2rpx 10rpx rgba(74, 144, 164, 0.06);
}

.total-price {
  font-size: 28rpx;
}

.total-price .price {
  font-size: 40rpx;
  font-weight: 700;
}

.submit-btn {
  background: linear-gradient(135deg, #E07A5F 0%, #E8967E 100%);
  color: #fff;
  padding: 20rpx 56rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(224, 122, 95, 0.3);
}

.submit-btn:active {
  opacity: 0.9;
}

.submit-btn.disabled {
  background: #D4DDE4;
  box-shadow: none;
}

/* 地址选择器样式 */
.address-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 80, 0.5);
  z-index: 200;
}

.address-picker {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 201;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #E8ECF1;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2C3E50;
}

.picker-add {
  font-size: 28rpx;
  color: #E07A5F;
  font-weight: 500;
}

.picker-list {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: auto;
}

.picker-item {
  background: #F8FAFB;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.picker-address-info {
  margin-bottom: 10rpx;
}

.picker-address-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.picker-address-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-right: 16rpx;
  color: #2C3E50;
}

.picker-address-phone {
  font-size: 26rpx;
  color: #5D6D7E;
}

.picker-default-tag {
  background: linear-gradient(135deg, #E07A5F 0%, #E8967E 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 16rpx;
}

.picker-address-detail {
  font-size: 26rpx;
  color: #95A5A6;
  line-height: 1.5;
}

.picker-empty {
  text-align: center;
  padding: 80rpx 0;
  color: #95A5A6;
}

.picker-footer {
  text-align: center;
  padding: 30rpx;
  border-top: 1rpx solid #E8ECF1;
  color: #5D6D7E;
  font-size: 28rpx;
}

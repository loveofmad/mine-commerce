.page-order {
  padding-bottom: 120rpx;
}

.address-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.address-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.address-content {
  flex: 1;
}

.address-info {
  margin-bottom: 8rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
}

.address-empty {
  flex: 1;
  text-align: center;
  color: #999;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  margin-left: 10rpx;
  flex-shrink: 0;
}

.order-items {
  background-color: #fff;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.order-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-item:last-child {
  border-bottom: none;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-title {
  font-size: 28rpx;
}

.item-sku {
  margin-top: 8rpx;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-bottom .price {
  font-size: 32rpx;
}

.remark-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.remark-label {
  font-size: 28rpx;
  margin-right: 20rpx;
}

.remark-input {
  flex: 1;
  font-size: 28rpx;
}

.amount-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.amount-row.total {
  border-top: 1rpx solid #f5f5f5;
  margin-top: 10rpx;
  padding-top: 20rpx;
  font-weight: bold;
}

.amount-row .price {
  font-size: 32rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #eee;
  padding: 0 30rpx;
  z-index: 100;
}

.total-price {
  font-size: 28rpx;
}

.total-price .price {
  font-size: 36rpx;
}

.submit-btn {
  background-color: #ff6600;
  color: #fff;
  padding: 16rpx 50rpx;
  border-radius: 36rpx;
  font-size: 30rpx;
}

.submit-btn.disabled {
  background-color: #ccc;
}

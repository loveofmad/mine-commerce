.page-user {
  min-height: 100vh;
  background: #f0f4f8;
}

/* 用户头部 */
.user-header {
  position: relative;
  background: linear-gradient(135deg, #4A90A4 0%, #6BB0C4 100%);
  padding: 80rpx 40rpx 50rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -80rpx;
  left: -50rpx;
}

.user-content {
  position: relative;
  display: flex;
  align-items: center;
  z-index: 1;
}

.login-content {
  cursor: pointer;
}

.user-avatar-wrap {
  margin-right: 28rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 40rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.user-id-wrap {
  display: inline-flex;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.login-tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 订单区域 */
.order-section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 164, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
}

.section-right {
  display: flex;
  align-items: center;
}

.section-more {
  font-size: 26rpx;
  color: #E07A5F;
  font-weight: 500;
}

.section-arrow {
  font-size: 32rpx;
  color: #E07A5F;
  margin-left: 8rpx;
}

.order-nav {
  display: flex;
  justify-content: space-around;
}

.order-nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.nav-emoji {
  font-size: 44rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #5D6D7E;
}

/* 菜单区域 */
.menu-section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 164, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #F0F4F8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #F8FAFB;
}

.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-emoji {
  font-size: 36rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #2C3E50;
  font-weight: 500;
}

.menu-arrow {
  font-size: 36rpx;
  color: #E07A5F;
}

/* 退出登录 */
.logout-section {
  margin: 40rpx 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.logout-btn {
  background: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 20rpx;
  color: #D4726A;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 164, 0.06);
}

.logout-btn:active {
  background: #F8FAFB;
}

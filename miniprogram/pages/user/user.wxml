<view class="page-user">
  <!-- 用户信息区域 -->
  <view class="user-header">
    <view class="header-bg">
      <view class="bg-circle circle-1"></view>
      <view class="bg-circle circle-2"></view>
    </view>
    <view class="user-content" wx:if="{{isLoggedIn}}">
      <view class="user-avatar-wrap">
        <image class="user-avatar" src="{{userInfo.avatar || '/static/default-avatar.png'}}" mode="aspectFill" />
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickname || userInfo.username}}</text>
        <view class="user-id-wrap">
          <text class="user-id">ID: {{userInfo.id}}</text>
        </view>
      </view>
    </view>
    <view class="user-content login-content" wx:else bindtap="onLoginTap">
      <view class="user-avatar-wrap">
        <view class="avatar-placeholder">👤</view>
      </view>
      <view class="user-info">
        <text class="user-name">微信一键登录</text>
        <text class="login-tip">点击头像快速登录</text>
      </view>
      <view class="login-arrow">›</view>
    </view>
  </view>

  <!-- 订单入口 -->
  <view class="order-section" wx:if="{{isLoggedIn}}">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <view class="section-right" bindtap="onOrderTap" data-status="">
        <text class="section-more">全部订单</text>
        <text class="section-arrow">›</text>
      </view>
    </view>
    <view class="order-nav">
      <view class="order-nav-item" bindtap="onOrderTap" data-status="0">
        <view class="nav-icon-wrap" style="background: rgba(255,102,0,0.1)">
          <text class="nav-emoji">💳</text>
        </view>
        <text class="nav-text">待付款</text>
      </view>
      <view class="order-nav-item" bindtap="onOrderTap" data-status="1">
        <view class="nav-icon-wrap" style="background: rgba(64,158,255,0.1)">
          <text class="nav-emoji">📦</text>
        </view>
        <text class="nav-text">待发货</text>
      </view>
      <view class="order-nav-item" bindtap="onOrderTap" data-status="2">
        <view class="nav-icon-wrap" style="background: rgba(103,194,58,0.1)">
          <text class="nav-emoji">🚚</text>
        </view>
        <text class="nav-text">待收货</text>
      </view>
      <view class="order-nav-item" bindtap="onOrderTap" data-status="3">
        <view class="nav-icon-wrap" style="background: rgba(230,162,60,0.1)">
          <text class="nav-emoji">✅</text>
        </view>
        <text class="nav-text">已完成</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onMenuItemTap" data-url="/pages/address/address">
      <view class="menu-icon-wrap" style="background: rgba(255,102,0,0.1)">
        <text class="menu-emoji">📍</text>
      </view>
      <text class="menu-text">收货地址</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuItemTap" data-url="">
      <view class="menu-icon-wrap" style="background: rgba(255,102,0,0.1)">
        <text class="menu-emoji">🎫</text>
      </view>
      <text class="menu-text">优惠券</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuItemTap" data-url="">
      <view class="menu-icon-wrap" style="background: rgba(64,158,255,0.1)">
        <text class="menu-emoji">❓</text>
      </view>
      <text class="menu-text">帮助中心</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuItemTap" data-url="">
      <view class="menu-icon-wrap" style="background: rgba(103,194,58,0.1)">
        <text class="menu-emoji">⚙️</text>
      </view>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <view class="logout-btn" bindtap="onLogout">退出登录</view>
  </view>
</view>

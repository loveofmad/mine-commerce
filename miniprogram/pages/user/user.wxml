<view class="page-user">
  <!-- 用户信息区域 -->
  <view class="user-header">
    <view class="user-avatar-wrap" wx:if="{{isLoggedIn}}">
      <image class="user-avatar" src="{{userInfo.avatar || '/static/default-avatar.png'}}" mode="aspectFill" />
      <view class="user-info">
        <text class="user-name">{{userInfo.nickname || userInfo.username}}</text>
        <text class="user-phone text-gray text-small">ID: {{userInfo.id}}</text>
      </view>
    </view>
    <view class="login-prompt" wx:else bindtap="onLoginTap">
      <image class="user-avatar" src="/static/default-avatar.png" mode="aspectFill" />
      <view class="user-info">
        <text class="user-name">微信一键登录</text>
        <text class="text-gray text-small">点击头像快速登录</text>
      </view>
    </view>
  </view>

  <!-- 订单入口 -->
  <view class="order-section" wx:if="{{isLoggedIn}}">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <view class="section-right" bindtap="onOrderTap" data-status="">
        <text class="text-gray text-small">全部订单</text>
        <image class="arrow-icon" src="/static/icon-arrow-right.png" />
      </view>
    </view>
    <view class="order-nav">
      <view class="order-nav-item" bindtap="onOrderTap" data-status="0">
        <image class="nav-icon" src="/static/icon-order-payment.png" />
        <text>待付款</text>
      </view>
      <view class="order-nav-item" bindtap="onOrderTap" data-status="1">
        <image class="nav-icon" src="/static/icon-order-shipping.png" />
        <text>待发货</text>
      </view>
      <view class="order-nav-item" bindtap="onOrderTap" data-status="2">
        <image class="nav-icon" src="/static/icon-order-delivery.png" />
        <text>待收货</text>
      </view>
      <view class="order-nav-item" bindtap="onOrderTap" data-status="3">
        <image class="nav-icon" src="/static/icon-order-completed.png" />
        <text>已完成</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onMenuItemTap" data-url="/pages/address/address">
      <image class="menu-icon" src="/static/icon-location.png" />
      <text class="menu-text">收货地址</text>
      <image class="arrow-icon" src="/static/icon-arrow-right.png" />
    </view>
    <view class="menu-item" bindtap="onMenuItemTap" data-url="">
      <image class="menu-icon" src="/static/icon-coupon.png" />
      <text class="menu-text">优惠券</text>
      <image class="arrow-icon" src="/static/icon-arrow-right.png" />
    </view>
    <view class="menu-item" bindtap="onMenuItemTap" data-url="">
      <image class="menu-icon" src="/static/icon-help.png" />
      <text class="menu-text">帮助中心</text>
      <image class="arrow-icon" src="/static/icon-arrow-right.png" />
    </view>
    <view class="menu-item" bindtap="onMenuItemTap" data-url="">
      <image class="menu-icon" src="/static/icon-settings.png" />
      <text class="menu-text">设置</text>
      <image class="arrow-icon" src="/static/icon-arrow-right.png" />
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <view class="logout-btn" bindtap="onLogout">退出登录</view>
  </view>
</view>

<view class="page-index">
  <!-- 顶部搜索栏 -->
  <view class="header">
    <view class="search-bar" bindtap="onSearchTap">
      <view class="search-input">
        <image class="search-icon" src="/static/icon-search.png" />
        <text class="search-placeholder">搜索土特产</text>
      </view>
    </view>
  </view>

  <!-- 轮播图 -->
  <view class="banner-wrapper">
    <swiper class="banner-swiper" indicator-dots autoplay circular interval="3000" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill" bindtap="onBannerTap" data-index="{{index}}" />
      </swiper-item>
    </swiper>
  </view>

  <!-- 分类导航 -->
  <view class="category-section">
    <view class="category-nav">
      <view class="category-item" wx:for="{{visibleCategories}}" wx:key="id" bindtap="onCategoryTap" data-id="{{item.id}}">
        <view class="category-icon-wrap">
          <text class="category-emoji">{{item.icon}}</text>
        </view>
        <text class="category-name">{{item.name}}</text>
      </view>
      <view class="category-item" wx:if="{{categories.length > 5}}" bindtap="toggleCategoryExpand">
        <view class="category-icon-wrap more-icon">
          <text class="more-text" wx:if="{{!categoryExpanded}}">···</text>
          <text class="more-text collapse-text" wx:else>收起</text>
        </view>
        <text class="category-name">{{categoryExpanded ? '收起' : '更多'}}</text>
      </view>
    </view>
    <view class="view-all-bar" bindtap="onViewAllCategory">
      <text class="view-all-text">全部分类</text>
      <text class="view-all-arrow">›</text>
    </view>
  </view>

  <!-- 推荐商品 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="section-title-bar"></view>
        <text class="section-title">推荐商品</text>
      </view>
    </view>
    <view class="product-grid">
      <view class="product-card" wx:for="{{productList}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
        <view class="product-image-wrap">
          <image class="product-image" src="{{item.mainImage}}" mode="aspectFill" />
          <view class="product-sales">已售{{item.sales || 0}}</view>
        </view>
        <view class="product-info">
          <text class="product-title text-ellipsis">{{item.title}}</text>
          <text class="product-subtitle text-ellipsis text-gray text-small">{{item.subtitle}}</text>
          <view class="product-price-row">
            <view class="price-wrap">
              <text class="price-symbol">¥</text>
              <text class="price-value">{{item.priceText}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载提示 -->
  <view class="loading-tip" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="text-gray">加载中...</text>
  </view>
  <view class="loading-tip" wx:if="{{!hasMore && productList.length > 0}}">
    <view class="line-divider">
      <view class="line"></view>
      <text class="text-gray">没有更多了</text>
      <view class="line"></view>
    </view>
  </view>
</view>

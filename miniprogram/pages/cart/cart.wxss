.page-cart {
  padding-bottom: 140rpx;
  background: linear-gradient(180deg, #f0f4f8 0%, #e8ecf1 100%);
  min-height: 100vh;
}

/* 空购物车 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon-wrap {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, #E8F4F8 0%, #D4ECEE 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 164, 0.15);
}

.empty-icon-text {
  font-size: 80rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #E07A5F 0%, #E8967E 100%);
  color: #fff;
  padding: 20rpx 80rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(224, 122, 95, 0.35);
}

.empty-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 购物车列表 */
.cart-list {
  padding: 20rpx 24rpx;
}

.cart-header {
  padding: 16rpx 8rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E50;
}

.cart-edit-btn {
  display: flex;
  align-items: center;
  background: rgba(74, 144, 164, 0.08);
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
}

.cart-edit-icon {
  font-size: 26rpx;
  color: #4A90A4;
  margin-right: 6rpx;
}

.cart-edit-text {
  font-size: 26rpx;
  color: #4A90A4;
  font-weight: 500;
}

/* 购物车商品卡片 */
.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 164, 0.08);
  border: 1rpx solid rgba(74, 144, 164, 0.06);
  transition: all 0.2s;
}

.cart-item:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 164, 0.12);
}

.item-check {
  padding: 10rpx;
  margin-right: 16rpx;
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #D4DDE4;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.check-circle.checked {
  background: linear-gradient(135deg, #E07A5F 0%, #E8967E 100%);
  border-color: #E07A5F;
  box-shadow: 0 2rpx 8rpx rgba(224, 122, 95, 0.3);
}

.check-mark {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.item-image-wrap {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.item-image {
  width: 100%;
  height: 100%;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  justify-content: space-between;
  height: 180rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 8rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-sku-wrap {
  display: inline-flex;
  background: linear-gradient(135deg, #F0F4F8 0%, #E8ECF1 100%);
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
  margin-bottom: 8rpx;
  align-self: flex-start;
}

.item-sku {
  font-size: 22rpx;
  color: #5D6D7E;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-wrap {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #E07A5F;
  font-weight: 600;
}

.price-value {
  font-size: 36rpx;
  color: #E07A5F;
  font-weight: 700;
}

.quantity-picker {
  display: flex;
  align-items: center;
  background: #F0F4F8;
  border-radius: 14rpx;
  padding: 4rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  background: #fff;
}

.qty-btn:active {
  background: #E8ECF1;
}

.qty-btn.minus {
  color: #95A5A6;
}

.qty-btn.plus {
  color: #4A90A4;
  background: rgba(74, 144, 164, 0.08);
}

.qty-btn-text {
  font-size: 32rpx;
  font-weight: 600;
}

.qty-value {
  width: 72rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

.item-delete {
  margin-left: 12rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(224, 122, 95, 0.08);
  border-radius: 50%;
}

.item-delete:active {
  background: rgba(224, 122, 95, 0.15);
}

.delete-icon {
  font-size: 30rpx;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #E8ECF1;
  padding: 0 24rpx;
  z-index: 100;
  box-shadow: 0 -4rpx 20rpx rgba(74, 144, 164, 0.08);
}

.check-all {
  display: flex;
  align-items: center;
  margin-right: 24rpx;
  padding: 10rpx;
}

.check-all-text {
  font-size: 28rpx;
  color: #2C3E50;
  margin-left: 12rpx;
  font-weight: 500;
}

.total-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.total-label {
  font-size: 28rpx;
  color: #5D6D7E;
}

.total-price-wrap {
  display: flex;
  align-items: baseline;
}

.total-price-symbol {
  font-size: 24rpx;
  color: #E07A5F;
  font-weight: 600;
}

.total-price {
  font-size: 40rpx;
  color: #E07A5F;
  font-weight: 700;
}

.checkout-btn {
  background: linear-gradient(135deg, #E07A5F 0%, #E8967E 100%);
  color: #fff;
  padding: 0 48rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(224, 122, 95, 0.35);
}

.checkout-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.checkout-btn.disabled {
  background: linear-gradient(135deg, #D4DDE4 0%, #C0C8D0 100%);
  box-shadow: none;
  color: #95A5A6;
}

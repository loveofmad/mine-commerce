.page-cart {
  padding-bottom: 120rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.empty-btn {
  margin-top: 30rpx;
}

.cart-list {
  padding: 20rpx 30rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.item-check {
  padding: 10rpx;
  margin-right: 10rpx;
}

.check-icon {
  width: 40rpx;
  height: 40rpx;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-title {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.item-sku {
  margin-bottom: 16rpx;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-bottom .price {
  font-size: 32rpx;
}

.quantity-picker {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 32rpx;
}

.qty-value {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
}

.item-delete {
  padding: 10rpx 20rpx;
  margin-left: 10rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #eee;
  padding: 0 30rpx;
  z-index: 100;
}

.check-all {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.total-info {
  flex: 1;
  font-size: 28rpx;
}

.total-info .price {
  font-size: 36rpx;
}

.checkout-btn {
  background-color: #ff6600;
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.checkout-btn.disabled {
  background-color: #ccc;
}

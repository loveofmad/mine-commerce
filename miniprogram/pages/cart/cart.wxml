<view class="page-cart">
  <!-- 空购物车 -->
  <view class="empty-tip" wx:if="{{cartList.length === 0}}">
    <view class="empty-icon-wrap">
      <text class="empty-icon-text">🛒</text>
    </view>
    <text class="empty-title">购物车空空如也</text>
    <text class="empty-desc text-gray">快去挑选心仪的商品吧</text>
    <view class="btn-primary empty-btn" bindtap="goHome">去逛逛</view>
  </view>

  <!-- 购物车列表 -->
  <view class="cart-list" wx:if="{{cartList.length > 0}}">
    <view class="cart-header">
      <text class="cart-title">购物车 ({{cartList.length}})</text>
      <text class="cart-edit" bindtap="onEditTap">{{isEdit ? '完成' : '编辑'}}</text>
    </view>
    <view class="cart-item" wx:for="{{cartList}}" wx:key="id">
      <view class="item-check" bindtap="onCheckTap" data-index="{{index}}">
        <view class="check-circle {{item.checked ? 'checked' : ''}}">
          <text class="check-mark" wx:if="{{item.checked}}">✓</text>
        </view>
      </view>
      <view class="item-image-wrap" bindtap="onProductTap" data-id="{{item.spuId}}">
        <image class="item-image" src="{{item.skuImage}}" mode="aspectFill" />
      </view>
      <view class="item-info" bindtap="onProductTap" data-id="{{item.spuId}}">
        <text class="item-title text-ellipsis">{{item.spuName}}</text>
        <view class="item-sku-wrap">
          <text class="item-sku">{{item.skuTitle}}</text>
        </view>
        <view class="item-bottom">
          <view class="price-wrap">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.price}}</text>
          </view>
          <view class="quantity-picker">
            <view class="qty-btn minus" bindtap="onQuantityMinus" data-index="{{index}}">-</view>
            <text class="qty-value">{{item.quantity}}</text>
            <view class="qty-btn plus" bindtap="onQuantityPlus" data-index="{{index}}">+</view>
          </view>
        </view>
      </view>
      <view class="item-delete" bindtap="onDeleteTap" data-index="{{index}}" wx:if="{{isEdit}}">
        <text class="delete-text">删除</text>
      </view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="bottom-bar safe-bottom" wx:if="{{cartList.length > 0}}">
    <view class="check-all" bindtap="onCheckAllTap">
      <view class="check-circle {{allChecked ? 'checked' : ''}}">
        <text class="check-mark" wx:if="{{allChecked}}">✓</text>
      </view>
      <text class="check-all-text">全选</text>
    </view>
    <view class="total-info">
      <text class="total-label">合计：</text>
      <view class="total-price-wrap">
        <text class="total-price-symbol">¥</text>
        <text class="total-price">{{totalPrice}}</text>
      </view>
    </view>
    <view class="checkout-btn {{totalCount === 0 ? 'disabled' : ''}}" bindtap="onCheckout">
      结算({{totalCount}})
    </view>
  </view>
</view>

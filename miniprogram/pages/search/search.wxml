<view class="page-search">
  <!-- 搜索栏 -->
  <view class="search-header">
    <view class="search-box">
      <text class="search-emoji">🔍</text>
      <input class="search-input" placeholder="搜索土特产" value="{{keyword}}" bindinput="onInput" bindconfirm="onSearch" focus="{{autoFocus}}" />
      <text class="clear-btn" wx:if="{{keyword}}" bindtap="onClear">✕</text>
    </view>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 搜索历史 -->
  <view class="history-section" wx:if="{{historyList.length > 0 && !searched}}">
    <view class="section-header">
      <text class="section-title">搜索历史</text>
      <text class="clear-history" bindtap="onClearHistory">清空</text>
    </view>
    <view class="history-tags">
      <view class="history-tag" wx:for="{{historyList}}" wx:key="*this" bindtap="onHistoryTap" data-keyword="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 热门搜索 -->
  <view class="history-section" wx:if="{{!searched}}">
    <view class="section-header">
      <text class="section-title">热门搜索</text>
    </view>
    <view class="history-tags">
      <view class="history-tag hot" wx:for="{{hotKeywords}}" wx:key="*this" bindtap="onHistoryTap" data-keyword="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="result-section" wx:if="{{searched}}">
    <view class="result-header" wx:if="{{productList.length > 0}}">
      <text class="result-count">共找到 {{total}} 件商品</text>
    </view>
    <view class="product-list">
      <view class="product-item" wx:for="{{productList}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
        <image class="product-image" src="{{item.mainImage}}" mode="aspectFill" lazy-load />
        <view class="product-info">
          <text class="product-title text-ellipsis">{{item.title}}</text>
          <text class="product-subtitle text-ellipsis">{{item.subtitle}}</text>
          <text class="product-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{!loading && productList.length === 0}}">
      <text class="empty-emoji">🔍</text>
      <text class="empty-text">未找到相关商品</text>
    </view>
    <view class="loading-tip" wx:if="{{loading}}">
      <text class="text-gray">加载中...</text>
    </view>
    <view class="loading-tip" wx:if="{{!hasMore && productList.length > 0}}">
      <text class="text-gray">没有更多了</text>
    </view>
  </view>
</view>

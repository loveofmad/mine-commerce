.page-search {
  min-height: 100vh;
  background: #f0f4f8;
}

.search-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  gap: 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F0F4F8;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-emoji {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C3E50;
}

.clear-btn {
  font-size: 28rpx;
  color: #95A5A6;
  padding: 0 8rpx;
}

.search-btn {
  font-size: 28rpx;
  color: #E07A5F;
  font-weight: 600;
  white-space: nowrap;
  padding: 8rpx 0;
}

.history-section {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
}

.clear-history {
  font-size: 24rpx;
  color: #95A5A6;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  background: #F0F4F8;
  border-radius: 30rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #5D6D7E;
  display: flex;
  align-items: center;
}

.tag-text {
  color: #5D6D7E;
}

.tag-delete {
  font-size: 22rpx;
  color: #B0BEC5;
  margin-left: 10rpx;
  padding: 4rpx;
}

.history-tag:active {
  background: #E8ECF1;
}

.history-tag.hot {
  background: rgba(224, 122, 95, 0.08);
  color: #E07A5F;
}

.result-section {
  padding: 0 24rpx;
}

.result-header {
  padding: 20rpx 0;
}

.result-count {
  font-size: 24rpx;
  color: #95A5A6;
}

.product-list {
  padding-bottom: 20rpx;
}

.product-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 164, 0.06);
}

.product-item:active {
  background: #F8FAFB;
}

.product-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-title {
  font-size: 28rpx;
  color: #2C3E50;
  font-weight: 500;
  line-height: 1.4;
}

.product-subtitle {
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 8rpx;
}

.product-price {
  font-size: 34rpx;
  font-weight: 600;
  color: #E07A5F;
  margin-top: 10rpx;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #95A5A6;
}

.loading-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #95A5A6;
  font-size: 26rpx;
}

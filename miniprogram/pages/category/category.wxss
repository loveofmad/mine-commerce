.page-category {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.search-bar {
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.search-input {
  background-color: #f5f5f5;
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}

.category-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.category-sidebar {
  width: 180rpx;
  background-color: #f5f5f5;
  height: 100%;
}

.sidebar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  border-left: 6rpx solid transparent;
}

.sidebar-item.active {
  background-color: #fff;
  color: #ff6600;
  border-left-color: #ff6600;
  font-weight: bold;
}

.sidebar-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 10rpx;
}

.product-list {
  flex: 1;
  padding: 20rpx;
  height: 100%;
}

.product-item {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  padding: 20rpx;
}

.product-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-title {
  font-size: 28rpx;
  color: #333;
}

.product-subtitle {
  margin-top: 8rpx;
}

.product-info .price {
  font-size: 32rpx;
  margin-top: 10rpx;
}

.loading-tip {
  text-align: center;
  padding: 30rpx 0;
}

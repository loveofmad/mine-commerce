.page-category {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f0f4f8;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 24rpx;
  background: #fff;
}

.search-input {
  background: #F0F4F8;
  border-radius: 40rpx;
  padding: 18rpx 30rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

/* 分类内容区 */
.category-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类栏 */
.category-sidebar {
  width: 180rpx;
  background: #fff;
  height: 100%;
  overflow-y: auto;
}

.sidebar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #5D6D7E;
  position: relative;
  transition: all 0.3s;
}

.sidebar-item.active {
  background: #F0F4F8;
  color: #4A90A4;
  font-weight: 600;
}

.sidebar-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background: linear-gradient(180deg, #4A90A4 0%, #6BB0C4 100%);
  border-radius: 0 4rpx 4rpx 0;
}

.sidebar-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 10rpx;
  border-radius: 12rpx;
}

.sidebar-emoji {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

/* 右侧商品列表 */
.product-list {
  flex: 1;
  padding: 20rpx;
  height: 100%;
  overflow-y: auto;
}

.product-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 164, 0.06);
}

.product-item:active {
  background: #F8FAFB;
}

.product-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-title {
  font-size: 28rpx;
  color: #2C3E50;
  font-weight: 500;
  line-height: 1.4;
}

.product-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #95A5A6;
}

.product-info .price {
  font-size: 34rpx;
  font-weight: 600;
  margin-top: 10rpx;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #95A5A6;
  font-size: 26rpx;
}

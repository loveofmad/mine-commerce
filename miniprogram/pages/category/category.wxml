<view class="page-category">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索土特产" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearchConfirm" />
  </view>

  <view class="category-content">
    <!-- 左侧分类 -->
    <scroll-view class="category-sidebar" scroll-y>
      <view class="sidebar-item {{currentCategoryId === item.id ? 'active' : ''}}"
            wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-id="{{item.id}}">
        <text class="sidebar-emoji">{{item.icon}}</text>
        <text>{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 右侧商品列表 -->
    <scroll-view class="product-list" scroll-y>
      <view class="product-item" wx:for="{{productList}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
        <image class="product-image" src="{{item.mainImage}}" mode="aspectFill" lazy-load />
        <view class="product-info">
          <text class="product-title text-ellipsis">{{item.title}}</text>
          <text class="product-subtitle text-ellipsis text-gray text-small">{{item.subtitle}}</text>
          <text class="price">¥{{item.priceText}}</text>
        </view>
      </view>
      <view class="loading-tip" wx:if="{{loading}}">
        <text class="text-gray">加载中...</text>
      </view>
      <view class="loading-tip" wx:if="{{!hasMore && productList.length > 0}}">
        <text class="text-gray">没有更多了</text>
      </view>
      <view class="empty-tip" wx:if="{{!loading && productList.length === 0}}">
        <text>暂无商品</text>
      </view>
    </scroll-view>
  </view>
</view>

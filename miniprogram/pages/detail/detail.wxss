.page-detail {
  padding-bottom: 140rpx;
  background: #f0f4f8;
}

/* 飞入购物车动画 */
.fly-ball {
  position: fixed;
  width: 30rpx;
  height: 30rpx;
  background: linear-gradient(135deg, #E07A5F 0%, #E8967E 100%);
  border-radius: 50%;
  z-index: 999;
  opacity: 0;
  transform: scale(0);
  transition: none;
}

.fly-active {
  animation: flyToCart 0.6s ease-in forwards;
}

@keyframes flyToCart {
  0% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
  100% {
    opacity: 0;
    transform: scale(0.3) translate(var(--fly-x), var(--fly-y));
  }
}

/* 轮播图 */
.swiper-wrapper {
  position: relative;
}

.detail-swiper {
  width: 100%;
  height: 750rpx;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.image-indicator {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  background: rgba(44, 62, 80, 0.6);
  color: #fff;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  backdrop-filter: blur(10px);
}

/* 商品信息 */
.detail-info {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.detail-info .price {
  font-size: 48rpx;
  font-weight: 700;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
  line-height: 1.4;
  color: #2C3E50;
}

.detail-subtitle {
  font-size: 26rpx;
  display: block;
  line-height: 1.5;
  color: #5D6D7E;
}

/* 通用区块 */
.detail-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #2C3E50;
}

/* 规格文本 */
.spec-text {
  font-size: 26rpx;
  color: #5D6D7E;
  line-height: 1.6;
}

/* SKU选择 */
.sku-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.sku-item {
  padding: 16rpx 32rpx;
  border: 2rpx solid #E8ECF1;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #5D6D7E;
  background: #F8FAFB;
  transition: all 0.3s;
}

.sku-item.active {
  border-color: #E07A5F;
  color: #E07A5F;
  background: linear-gradient(135deg, #FDF2EF 0%, #F9E6E0 100%);
  font-weight: 500;
}

/* 数量选择 */
.quantity-picker {
  display: inline-flex;
  align-items: center;
  background: #fff;
  border: 2rpx solid #E8ECF1;
  border-radius: 12rpx;
}

.qty-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #5D6D7E;
}

.qty-btn:active {
  background: #F0F4F8;
}

.qty-btn.minus {
  border-right: 2rpx solid #E8ECF1;
}

.qty-btn.plus {
  border-left: 2rpx solid #E8ECF1;
  color: #E07A5F;
}

.qty-value {
  width: 80rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #2C3E50;
}

/* 商品详情 */
.detail-content {
  width: 100%;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #fff;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #E8ECF1;
  z-index: 100;
  box-shadow: 0 -2rpx 10rpx rgba(74, 144, 164, 0.06);
}

.bar-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
}

.bar-icon-img {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
}

.bar-emoji {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #5D6D7E;
}

.bar-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 40rpx;
  transition: all 0.3s;
}

.bar-btn:active {
  transform: scale(0.98);
}

.bar-btn-cart {
  flex: 0 0 auto;
  width: 220rpx;
  background: #fff;
  color: #E07A5F;
  border: 2rpx solid #E07A5F;
  margin-right: 16rpx;
}

.bar-btn-buy {
  flex: 1;
  background: linear-gradient(135deg, #E07A5F 0%, #E8967E 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(224, 122, 95, 0.4);
  margin-right: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
}
